{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Issuer": "ItmIdentityServer",
    "Audience": "ItmStoreApis",
    "SecretKey": "ITM-Super-Secret-Key-For-JWT-Class-2026-Nivel5"
  },
  "ReverseProxy": {
    "Routes": {
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/bodega/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/inventory/{**catch-all}" }
        ]
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": {
          "Path": "/api/products/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/products/{**catch-all}" }
        ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/orders/{**catch-all}" }
        ],
        "Metadata": {
          "RateLimiterPolicy": "purchase"
        }
      },
      "search-route": {
        "ClusterId": "search-cluster",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/search/{**catch-all}" }
        ]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/hubs/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "inventory-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5293" }
        }
      },
      "product-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5298" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5027" }
        }
      },
      "search-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5100" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://localhost:5089" }
        }
      }
    }
  }
}
